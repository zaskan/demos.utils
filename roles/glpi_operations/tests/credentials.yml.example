# SPDX-License-Identifier: MIT-0
# Secrets — copy to credentials.yml and pass at runtime:
#   ansible-playbook -i inventory test.yml -e @credentials.yml
#
# Uncomment ONE block (Method C = username + password only, no App-Token).

# --- Method A: application token + user remote access key ---
# glpi_app_token: "CHANGEME_APP_TOKEN"
# glpi_user_token: "CHANGEME_USER_TOKEN"

# --- Method B: application token + GLPI login (HTTP Basic) ---
# glpi_app_token: "CHANGEME_APP_TOKEN"
# glpi_username: "glpi"
# glpi_password: "CHANGEME_PASSWORD"

# --- Method C: GLPI login only (no App-Token; GLPI must allow API without app token) ---
# glpi_username: "glpi"
# glpi_password: "CHANGEME_PASSWORD"
