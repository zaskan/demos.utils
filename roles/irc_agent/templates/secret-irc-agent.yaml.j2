---
apiVersion: v1
kind: Secret
metadata:
  name: {{ irc_agent_secret_name }}
  namespace: {{ irc_agent_namespace }}
  labels:
    app: {{ irc_agent_app }}
    app.kubernetes.io/managed-by: irc_agent
type: Opaque
# AAP token keys always present for envFrom (patch or vault when empty at first apply).
stringData:
  LLM_API_KEY: "{{ irc_agent_llm_api_key | string }}"
  IRC_PASSWORD: "{{ irc_agent_irc_password | string }}"
  AAP_MCP_SERVER_TOKEN: "{{ irc_agent_aap_mcp_server_token | default('', true) | string }}"
  IRC_AGENT_AAP_MCP_SERVER_TOKEN: "{{ irc_agent_aap_mcp_server_token | default('', true) | string }}"
